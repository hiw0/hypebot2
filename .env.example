# Copy to .env and fill in. Never commit the real .env.

# --- Hyperliquid ---
# Use an API wallet, not your main key. Hex (0x-prefixed) private key for signing.
HL_PRIVATE_KEY=
HL_WALLET_ADDRESS=
HL_ENV=testnet            # testnet | mainnet

# --- Redis ---
# Local without Docker:
REDIS_URL=redis://localhost:6379/0
# Docker Compose sets this automatically to redis://redis:6379/0.
# Managed Redis example:
# REDIS_URL=redis://:password@your-redis-host:6379/0

# --- Bot ---
BOT_MODE=paper            # paper | live  (start with paper)
BASE_COIN=BTC
QUOTE=USDC
MAX_LEVERAGE=3
MAX_POSITION_USD=1000
RISK_PER_TRADE=0.01       # fraction of equity per trade
FEE_RATE=0.0005           # backtest assumption
SLIPPAGE_BPS=2            # backtest assumption

# --- Strategy ---
STRATEGY=mean_reversion   # mean_reversion | momentum
# Mean reversion
MR_FAST=5
MR_SLOW=12
MR_THRESHOLD=0.001
# Momentum (Donchian breakout)
MOM_LOOKBACK=5

# --- Optional execution ---
TWAP_MINUTES=
TWAP_RANDOMIZE=false
REDUCE_ONLY=false
AGGRESSIVE_BPS=0

# --- Risk ---
DAILY_LOSS_LIMIT_USD=200  # stop trading if realized PnL <= -USD today
DAILY_LOSS_LIMIT_PCT=0    # 0 disables
DEADMAN_SECONDS=60        # scheduled-cancel refresh interval

# --- Market data ---
MARKETDATA_SOURCE=ws      # ws | poll
CANDLE_INTERVAL=1m

# --- Logging / dashboard ---
LOG_LEVEL=INFO
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# --- Backtesting ---
BACKTEST_DATA_PATH=data/BTCUSDC_1h.csv
